{
    "extends": "solhint:recommended",
    "rules": {
        "compiler-version": ["error", "^0.8.24"],
        "func-visibility": ["error", {"ignoreConstructors": true}],
        "no-empty-blocks": "off",
        "max-line-length": ["warn", 110],
        "reason-string": ["warn", {"maxLength": 80}],
        "named-parameters-mapping": "off"
    }
}
